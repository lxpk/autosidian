{
	"name": "autosidian",
	"version": "1.0.0",
	"description": "Automate Folder Notes, Waypoint, Iconize, and Pixel Banner workflows in Obsidian.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"test:unit": "vitest run",
		"test:integration": "npm run build && node e2e/scripts/sync-plugin.mjs && node e2e/scripts/verify-snapshot.mjs",
		"test:integration:pixel-folder-notes": "node e2e/scripts/apply-pixel-banner-to-folder-notes.mjs",
		"test:integration:pixel-folder-notes:write": "node e2e/scripts/apply-pixel-banner-to-folder-notes.mjs --write",
		"test": "npm run test:unit && npm run test:integration",
		"test:e2e": "npm run test:integration && node e2e/spec/autosidian-settings.mjs",
		"test:integration:open": "npm run test:integration && node e2e/scripts/open-obsidian.mjs"
	},
	"keywords": [
		"obsidian",
		"obsidian-plugin"
	],
	"license": "Apache-2.0",
	"devDependencies": {
		"@types/node": "^20.14.0",
		"esbuild": "^0.25.0",
		"puppeteer-core": "^24.0.0",
		"tslib": "2.6.0",
		"typescript": "^5.5.0",
		"vitest": "^3.0.0"
	},
	"dependencies": {
		"obsidian": "latest"
	}
}
